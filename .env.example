NEXT_PUBLIC_DONATION_URL=https://example.com/donate
NEXT_PUBLIC_SITE_URL=https://plugat-tzav.onrender.com
NEXT_PUBLIC_CONTACT_EMAIL=contact@plugat-tzav.org

# NextAuth.js — required for authentication
AUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# First admin email — gets admin role on first login
ADMIN_EMAIL=your-email@gmail.com

# Render sets this automatically
# AUTH_URL=https://plugat-tzav.onrender.com
